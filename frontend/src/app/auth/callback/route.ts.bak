// ════════════════════════════════════════════════════════════════
// app/auth/callback/route.ts — Supabase Email Confirmation Handler
// Supabase redirects users HERE after they click the email
// verification link. We exchange the code for a session, then
// redirect to the appropriate dashboard.
//
// This is REQUIRED for email confirmation to work. Without it,
// Supabase's redirect lands on a 404 page.
// ════════════════════════════════════════════════════════════════

import { createServerClient, type CookieOptions } from "@supabase/ssr";
import { cookies } from "next/headers";
import { NextResponse, type NextRequest } from "next/server";

export async function GET(request: NextRequest) {
  const { searchParams, origin } = new URL(request.url);
  const code = searchParams.get("code");
  const next = searchParams.get("next") ?? "/";

  if (!code) {
    // No code = bad link or expired — send to login with error
    return NextResponse.redirect(`${origin}/auth/login?error=invalid_link`);
  }

  const cookieStore = await cookies();

  const supabase = createServerClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
    {
      cookies: {
        get(name: string) {
          return cookieStore.get(name)?.value;
        },
        set(name: string, value: string, options: CookieOptions) {
          cookieStore.set({ name, value, ...options });
        },
        remove(name: string, options: CookieOptions) {
          cookieStore.delete({ name, ...options });
        },
      },
    }
  );

  // Exchange the one-time code for a user session
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);

  if (error || !data.session) {
    return NextResponse.redirect(`${origin}/auth/login?error=session_failed`);
  }

  // Redirect to complete page to finish profile creation
  const nextEncoded = encodeURIComponent(next);
  return NextResponse.redirect(`${origin}/auth/callback/complete?next=${nextEncoded}`);
}
