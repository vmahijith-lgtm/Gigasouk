# ═══════════════════════════════════════════════════════════════════════════
# GigaSouk — root .gitignore
# Keep secrets, build output, and machine-local caches out of Git.
# ═══════════════════════════════════════════════════════════════════════════

# ------------------ Secrets (never commit) ----------------------------------
# Keep example files (e.g. .env.example) in the repo, but ignore real .env files.
.env
.env.*.local
.env.local
backend/.env
frontend/.env.local
*.pem
*.p12
*.key

# ------------------ Python --------------------------------------------------
# Virtualenvs
.venv/
venv/
env/
backend/.venv/

# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class
.Python

# Packaging / build
build/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST

# Test / coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# Tools
.tox/
.nox/

# ------------------ Node / Next.js / frontend -------------------------------
node_modules/
**/node_modules/
frontend/.next/
frontend/out/
.next/
out/
.turbo/
.vercel/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Next build artifacts
/.next
/.next/**

# ------------------ OS / editors / IDEs ------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors
*~
*.swp
*.swo
.idea/
*.sublime-project
*.sublime-workspace
.vscode/
.history/

# JetBrains
/.idea/
*.iml

# ------------------ Logs / temp / runtime ----------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.temp
*.cache
celerybeat-schedule
*.pid

# ------------------ Database / local state ---------------------------------
*.sqlite3
*.db
*.db-journal

# ------------------ Docker -------------------------------------------------
docker-compose.override.yml
.env.docker

# ------------------ Misc / tools -------------------------------------------
# Local environment markers
.python-version

# Editorconfig/project settings that may be local
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# ------------------ Context / generated -----------------------------------
context/

# End of .gitignore
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
