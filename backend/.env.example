# ════════════════════════════════════════════════════════════════
# Backend environment template — Railway / local
#
# Copy values into Railway → Variables (or a local `.env` — never commit secrets).
# ════════════════════════════════════════════════════════════════

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ROUTE_ACCOUNT=
RAZORPAY_WEBHOOK_SECRET=

SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Public frontend URL (links in emails / notifications) — your Vercel production domain
APP_URL=https://your-app.vercel.app

# CORS: comma-separated origins that may call this API from the browser
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Optional: allow every Vercel preview deployment (HTTPS only). Remove if you only use production.
# ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$

GOOGLE_MAPS_API_KEY=

QC_SCALE_MM_PER_PX=0.1
QC_TOLERANCE_MM=0.5
