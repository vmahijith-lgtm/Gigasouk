# ════════════════════════════════════════════════════════════════
# .env.example — GigaSouk Environment Variables
# Platform : GigaSouk Manufacturing-as-a-Service
# Domain   : gigasouk.com
# Founder  : Anirudh S Raj (anirudhsraj11@gmail.com)
#
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in every value below (remove the placeholder text)
#   3. NEVER commit your real .env file to GitHub
#      (it contains secret keys — keep it private)
#
# WHERE TO FIND EACH VALUE:
#   Every value has a comment telling you exactly where to get it.
# ════════════════════════════════════════════════════════════════


# ── SUPABASE ─────────────────────────────────────────────────────
# Where to find: Supabase Dashboard → Settings → API
#
# SUPABASE_URL      → "Project URL" (starts with https://xxxx.supabase.co)
# SUPABASE_ANON_KEY → "anon public" key (safe to use in frontend)
# SUPABASE_SERVICE_KEY → "service_role" key (KEEP SECRET — backend only)

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here


# ── RAZORPAY ─────────────────────────────────────────────────────
# Where to find: Razorpay Dashboard → Settings → API Keys
# Start with TEST keys. Switch to LIVE keys when ready to go live.
#
# RAZORPAY_KEY_ID     → starts with rzp_test_ (test) or rzp_live_ (live)
# RAZORPAY_KEY_SECRET → shown only once — copy immediately
# RAZORPAY_ROUTE_ACCOUNT → Settings → Route → Linked Account ID

RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_ROUTE_ACCOUNT=your_route_account_id_here
# RAZORPAY_WEBHOOK_SECRET → Razorpay Dashboard → Webhooks → Secret
#   Used to verify HMAC-SHA256 signatures on inbound payment webhooks.
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here


# ── SHIPROCKET ───────────────────────────────────────────────────
# Where to find: Shiprocket Dashboard → Settings → API
# Use the same email and password you use to log in to Shiprocket.
# The API generates a token using these credentials.

SHIPROCKET_EMAIL=your-shiprocket-login-email@gmail.com
SHIPROCKET_PASSWORD=your-shiprocket-password


# ── TWILIO (WhatsApp Notifications) ─────────────────────────────
# Where to find: Twilio Console → Account Info (top of dashboard)
#
# TWILIO_ACCOUNT_SID  → starts with AC
# TWILIO_AUTH_TOKEN   → shown below the SID
# TWILIO_WHATSAPP_FROM:
#   Testing: use whatsapp:+14155238886 (Twilio sandbox number)
#   Production: use your approved WhatsApp Business number
#               format: whatsapp:+91XXXXXXXXXX

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886


# ── RESEND (Email Notifications) ─────────────────────────────────
# Where to find: Resend Dashboard → API Keys → Create API Key
#
# RESEND_API_KEY    → starts with re_
# RESEND_FROM_EMAIL → must be a verified domain on Resend
#                     Use noreply@gigasouk.com once domain is verified

RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@gigasouk.com


# ── APP SETTINGS ─────────────────────────────────────────────────
# APP_URL → your live frontend URL (used in notification links)
# ALLOWED_ORIGINS → comma-separated list of allowed frontend URLs
#
# During development:
#   APP_URL=http://localhost:3000
#   ALLOWED_ORIGINS=http://localhost:3000
#
# After going live:
#   APP_URL=https://gigasouk.com
#   ALLOWED_ORIGINS=https://gigasouk.com,https://www.gigasouk.com

APP_URL=https://gigasouk.com
ALLOWED_ORIGINS=https://gigasouk.com,https://www.gigasouk.com


# ── QC SETTINGS ──────────────────────────────────────────────────
# QC_SCALE_MM_PER_PX → how many mm each pixel represents in part photos
#                      This depends on how close the camera is to the part.
#                      Default 0.1 = 1 pixel is 0.1mm (camera ~30cm away)
# QC_TOLERANCE_MM    → maximum allowed dimension error in mm
#                      Default 0.5 = half a millimetre tolerance

QC_SCALE_MM_PER_PX=0.1
QC_TOLERANCE_MM=0.5


# ── GOOGLE MAPS (Optional — backend geocoding) ─────────────────
# Where to find: Google Cloud Console → APIs & Services → Credentials
# Used to geocode a pincode → lat/lng when the customer hasn't
# provided coordinates. Routing still works without this key
# but falls back to manual admin review for unknown pincodes.

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
