# ════════════════════════════════════════════════════════════════
# .env.local.example — GigaSouk Frontend Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.local.example .env.local
#   2. Fill in each value below
#   3. NEVER commit .env.local to GitHub
#
# NEXT_PUBLIC_ prefix = safe to expose to the browser
# Values without prefix = server-side only
# ════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Canonical site URL for OAuth redirectTo (must match Supabase Auth → Redirect URLs). Production on Vercel: https://gigasouk.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Backend API ───────────────────────────────────────────────────
# Your Railway backend URL (found in Railway dashboard after deploy)
# Development: http://localhost:8000
# Production: your Railway HTTPS URL (Settings → Networking), no trailing slash
NEXT_PUBLIC_API_URL=https://your-service.up.railway.app

NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-api-key-here
