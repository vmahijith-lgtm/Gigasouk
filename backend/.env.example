# Copy to `.env` and fill in values. Never commit real secrets.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Razorpay (server only — never expose RAZORPAY_KEY_SECRET or webhook secret to the frontend)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Optional route transfers
RAZORPAY_ROUTE_ACCOUNT=

# Shiprocket (server only)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# App
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
